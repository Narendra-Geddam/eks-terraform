aws_region         = "ap-south-1"
project_name       = "my-platform"
environment        = "dev"
cluster_name       = "my-eks-cluster"
kubernetes_version = "1.31"
vpc_cidr           = "10.20.0.0/16"

# Restrict API endpoint access to specific CIDRs in production
# Default allows all traffic - change this for security!
cluster_endpoint_public_access_cidrs = ["0.0.0.0/0"]

# EKS managed add-ons (set to specific versions or use "latest")
# cluster_addons = {
#   coredns    = "latest"
#   kube-proxy = "latest"
#   vpc-cni    = "latest"
# }

node_instance_types = ["t3.medium"]
node_desired_size   = 2
node_min_size       = 1
node_max_size       = 3
